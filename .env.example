# =============================================================================
# Hyperlane Validator & Relayer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before running setup-config.sh
#
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#   ./setup-config.sh
#
# NEVER commit .env to git — it contains private keys!
# =============================================================================

# ── AWS S3 (Validator checkpoint storage) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# S3 bucket name where the validator publishes signed checkpoints
# Must be globally unique — use your name/identifier
S3_BUCKET=hyperlane-validator-signatures-YOUR-NAME-terraclassic

# ── Database paths ─────────────────────────────────────────────────────────────
# Use /tmp to avoid filling the physical disk with RocksDB data
# WARNING: /tmp is cleared on server reboot — agents will re-index from index.from
VALIDATOR_DB=/tmp/hyp/validator/db
RELAYER_DB=/tmp/hyp/relayer/db

# ── Private keys (hex format: 0x + 64 hex chars) ──────────────────────────────

# Terra Classic — cosmosKey (secp256k1)
# How to get: terrad keys export YOUR_KEY --keyring-backend file --unarmored-hex --unsafe
# Add 0x prefix to the output
TERRA_PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# BSC — hexKey (secp256k1, same format as Ethereum)
# How to get: cast wallet new  (outputs Private Key + Address)
BSC_PRIVATE_KEY=0xbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# Ethereum — hexKey (secp256k1)
# How to get: cast wallet new
ETH_PRIVATE_KEY=0xcccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc

# Solana — hexKey (ED25519, first 32 bytes of the 64-byte keypair)
# How to get:
#   python3 -c "import json; kp=json.load(open('solana-keypair.json')); print('0x'+bytes(kp[:32]).hex())"
SOLANA_PRIVATE_KEY=0xdddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd
