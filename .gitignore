# Arquivos de ambiente com credenciais
.env

# Config files with private keys (generated by setup-config.sh — never commit)
hyperlane/validator.*.json
hyperlane/relayer*.json
hyperlane/relayer-mainnet.json
hyperlane/relayer-testnet.json

# Backup files generated by check-block-height-mainnet.sh
hyperlane/*.bak

# Templates (.template files ARE committed — only generated .json files are ignored)
# !hyperlane/*.template  ← templates are NOT ignored (they have no real keys)

# Dados dos agentes
validator/
relayer/
validator-testnet/
relayer-testnet/

# Logs
*.log

# Docker
docker-compose.override.yml

solana-keypair.json
